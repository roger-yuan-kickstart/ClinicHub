{
  "name": "clinichub",
  "version": "0.1.0",
  "private": true,
  "description": "Clinic workflow automation (Phase 1 MVP)",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "ts-node src/runner.ts",
    "dev": "ts-node-dev src/runner.ts",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "selector-capture": "ts-node src/tools/selectorCapture.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "playwright": "^1.49.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
