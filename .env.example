# Run mode
# true = log-only for writes (safe) | false = execute real actions
DRY_RUN=true
# true = pause before each write step | false = do not pause
STEP_MODE=false

# Third-party medical system entry URL (required). Account and password are entered in the
# browser by the end user and are never stored in .env or config.
THIRD_PARTY_URL=

# Paths
SCREENSHOT_DIR=./screenshots
LOG_DIR=./logs
SESSION_STATE_PATH=./recordings/auth.json

# Manual login wait (setup-session / ThirdPartyLoginPage.waitForManualLogin). Default 900000 (15 min). 0 = unlimited.
MANUAL_LOGIN_TIMEOUT_MS=900000

# Playwright
BROWSER_HEADLESS=false
SLOW_MO_MS=500

# Logging
LOG_LEVEL=info

# Supervised confirmation UI (Story 004b)
SUPERVISED_MODE=false
SUPERVISED_UI_PORT=7788
# Optional: milliseconds to keep the supervised panel server up after startup (preview empty UI; 0 = off)
SUPERVISED_UI_SMOKE_HOLD_MS=0
