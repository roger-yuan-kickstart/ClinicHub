# Run mode
# true = log-only for writes (safe) | false = execute real actions
DRY_RUN=true
# true = pause before each write step | false = do not pause
STEP_MODE=false

# Third-party medical system (test account placeholders — replace in local .env)
THIRD_PARTY_URL=
THIRD_PARTY_USERNAME=
THIRD_PARTY_PASSWORD=

# Web mail platform (test account placeholders — replace in local .env)
WEBMAIL_URL=
WEBMAIL_USERNAME=
WEBMAIL_PASSWORD=

# Test safety: outbound mail recipient is forced to this address
TEST_EMAIL_RECIPIENT=

# Paths
SCREENSHOT_DIR=./screenshots
LOG_DIR=./logs
SESSION_STATE_PATH=./recordings/auth.json

# Playwright
BROWSER_HEADLESS=false
SLOW_MO_MS=500

# Logging
LOG_LEVEL=info

# Supervised confirmation UI (Story 004b — optional until implemented)
SUPERVISED_MODE=false
